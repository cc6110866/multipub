{
  "manifest_version": 3,
  "name": "MultiPub - 公众号排版助手",
  "version": "1.0.0",
  "description": "将 Markdown 内容一键注入公众号编辑器，告别繁琐排版",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://mp.weixin.qq.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MultiPub"
  },
  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://multipub-five.vercel.app/*"
      ],
      "js": ["multipub-web.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://multipub-five.vercel.app/*"
    ]
  }
}
